    {
      "name": "Read",
      "description": "Read file contents. Supports images (JPEG, PNG up to 5MB). Truncates at 2400 lines by default.",
      "type": "file_path (required), offset, limit"
    },
    {
      "name": "LS",
      "description": "List directory contents with optional pattern-based filtering and ignore patterns.",
      "type": "directory_path, ignorePatterns[]"
    },
    {
      "name": "Execute",
      "description": "Execute shell commands with timeout. Each command runs in isolated shell. Supports background processes.",
      "type": "command (required), timeout, fireAndForget, riskLevel"
    },
    {
      "name": "Edit",
      "description": "Find and replace text in files. Requires Read first. old_str must be unique or use change_all.",
      "type": "file_path, old_str, new_str (required), change_all"
    },
    {
      "name": "Grep",
