    {
      "id": "execute",
      "title": "Execute Tool",
      "content": [
        {
          "type": "callout",
          "variant": "orange",
          "html": "<p><strong>Each Execute runs in a NEW, ISOLATED shell.</strong> Nothing persists:</p>"
        },
        {
          "type": "table",
          "headers": [
            "Level",
            "Description",
            "Examples"
          ],
          "rows": [
            [
              "LOW",
              "Read-only operations, no side effects",
              "echo, pwd, whoami, date, cat, git status, git log, git diff, ls"
            ],
            [
              "MEDIUM",
              "Significant but recoverable side effects",
              "touch, mkdir, mv, cp, npm install, pip install, git commit, make"
            ],
            [
              "HIGH",
              "Security implications, irreversible changes",
              "sudo commands, rm -rf, curl | bash, git push, database migrations"
            ]
          ]
        }
      ],
      "subsections": [
