      "title": "Instruction Hierarchy",
      "content": [
        {
          "type": "callout",
          "variant": "blue",
          "html": "<strong>Conflict example:</strong> if user asks to skip verification for latest information,\n          the system rule still requires web verification for unstable/time-sensitive facts."
        },
        {
          "type": "text",
          "html": "The agent follows a strict priority stack. If two instructions conflict, higher level wins."
        },
        {
          "type": "flow",
          "steps": [
