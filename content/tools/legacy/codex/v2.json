    {
      "id": "debug",
      "title": "Debug Playbook for Students",
      "content": [
        {
          "type": "callout",
          "variant": "blue",
          "html": "<strong>Teaching tip:</strong> ask students to map each observed behavior to one rule in this file.\n          It makes agent decisions auditable and easier to reason about."
        },
        {
          "type": "text",
          "html": "If behavior looks wrong, inspect in this exact order:"
        },
        {
          "type": "flow",
          "steps": [
            {
              "num": "1",
              "title": "Check instruction hierarchy conflict",
              "description": "System or developer rules may override what user asked."
            },
            {
              "num": "2",
              "title": "Check runtime mode and permissions",
              "description": "Collaboration mode, sandbox mode, and approval policy change behavior."
            },
            {
              "num": "3",
              "title": "Check tool-selection path",
              "description": "Wrong tool choice can cause incomplete context or invalid edits."
            },
            {
              "num": "4",
              "title": "Check AGENTS.md and skill triggers",
              "description": "Missed skill routing often explains unexpected strategy changes."
            },
            {
              "num": "5",
              "title": "Check validation coverage",
              "description": "Some failures come from unrun tests or skipped verification steps."
            }
          ]
        }
      ],
