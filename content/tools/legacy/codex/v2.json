    {
      "id": "skills",
      "title": "Skills and AGENTS.md",
      "content": [
        {
          "type": "callout",
          "variant": "purple",
          "html": "<strong>Scope rule:</strong> AGENTS.md instructions apply to the directory tree where the file sits.\n          Nested AGENTS.md files override parent-level instructions in deeper folders."
        },
        {
          "type": "text",
          "html": "Skills are local instruction bundles described by <code>SKILL.md</code> files. If a user names a skill,\n          or task intent clearly matches one, the agent must load and follow that skill for the turn."
        },
        {
          "type": "table",
          "headers": [
            "Behavior",
            "Rule"
          ],
          "rows": [
            [
              "Skill Trigger",
              "If named directly or clearly relevant by description, use it."
            ],
            [
              "File Loading",
              "Read only needed parts first, then expand only if blocked."
            ],
            [
              "Relative Paths",
              "Resolve relative files from the skill directory first."
            ],
            [
              "Multiple Skills",
              "Use minimal set that covers request and state order."
            ],
            [
              "Missing Skill",
              "State issue briefly and continue with best fallback."
            ]
          ]
        }
      ],
      "subsections": []
