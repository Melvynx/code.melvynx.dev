    {
      "id": "decision",
      "title": "Tool Selection Rules",
      "content": [
        {
          "type": "text",
          "html": "The agent uses deterministic heuristics to choose tools quickly and safely."
        },
        {
          "type": "table",
          "headers": [
            "Situation",
            "Default Action",
            "Reason"
          ],
          "rows": [
            [
              "Need file list or text search in repo",
              "Use exec_command with rg --files or rg",
              "Fastest and most token-efficient."
            ],
            [
              "Need several independent reads",
              "Use multi_tool_use.parallel",
              "Reduces latency."
            ],
            [
              "Single-file focused edit",
              "Use apply_patch",
              "Precise, auditable diff-like change."
            ],
            [
              "Cross-file repetitive edits",
              "Use shell scripting where appropriate",
              "More efficient than manual patch chunks."
            ],
            [
              "Programming docs/API behavior",
              "Prefer primary docs via Context7/official sources",
              "Reduces stale or secondary-source errors."
            ],
            [
              "Question is time-sensitive",
              "Browse and verify before answer",
              "Avoid outdated claims."
            ],
            [
              "User asks for latest/current/today",
              "Always verify with web tools",
              "Temporal instability."
            ]
          ]
