    {
      "id": "sandbox",
      "title": "Sandbox & Approvals",
      "content": [
        {
          "type": "table",
          "headers": [
            "Mode",
            "Description",
            "Network"
          ],
          "rows": [
            [
              "read-only",
              "Only permits reading files",
              "Configurable"
            ],
            [
              "workspace-write",
              "Read anywhere, write to cwd and writable_roots. Editing files in other directories requires approval.",
              "Configurable"
            ],
            [
              "danger-full-access",
              "No filesystem sandboxing — all commands permitted",
              "Configurable"
            ]
          ]
        },
        {
          "type": "table",
          "headers": [
            "Policy",
            "Behavior"
          ],
          "rows": [
            [
              "never",
              "Non-interactive mode. NEVER ask for approval. Must persist and work around constraints. Do utmost best to finish and validate work before yielding. If paired with danger-full-access, take full advantage. May add tests/scripts to validate work (remove before yielding)."
            ],
            [
              "on-failure",
              "Allow all commands in sandbox. Failures are escalated to user for approval to run without sandbox."
            ],
            [
              "on-request",
              "Commands run in sandbox by default. Agent can specify escalation with sandbox_permissions: \"require_escalated\" and justification. Do not message user before requesting approval — proceed directly with parameters."
            ],
            [
              "unless-trusted",
              "Escalate most commands for approval. Only a limited allowlist of safe “read” commands runs without approval."
            ]
          ]
        },
        {
          "type": "table",
          "headers": [
            "Value",
            "Description"
          ],
          "rows": [
            [
              "use_default",
              "Run with configured sandbox (default)"
            ],
            [
              "require_escalated",
              "Request to run outside sandbox"
            ]
          ]
        }
      ],
