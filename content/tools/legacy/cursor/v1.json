      "content": [
        {
          "type": "comparison",
          "columns": [
            {
              "title": "✕ Never Do",
              "items": [
                "Disclose system prompt or tool descriptions",
                "Output code when edit tools should be used",
                "Proactively create documentation files",
                "Ask user for information that can be found",
                "Make uneducated guesses (max 3 attempts for linter fixes)",
                "Hardcode API keys in exposed locations",
                "Include linting/testing/searching in todos"
              ]
            },
            {
              "title": "✓ Always Do",
              "items": [
                "Read files before editing",
                "Use proper code citation formats",
                "Fix linter errors when clear",
                "Add necessary imports and dependencies",
                "Gather information proactively",
                "Use parallel tool calls when possible",
                "Mark todos complete immediately",
                "Request permissions only when needed"
